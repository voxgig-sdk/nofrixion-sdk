      op: update: method: *PUT
    }
    path: "/api/v1/userinvites/{id}/details": {
      rename: param: "id": *"userinvite_id"
      op: load: method: *GET
    }
  }

  entity: virtual: {
    path: "/api/v1/accounts/{accountID}/virtual": {
