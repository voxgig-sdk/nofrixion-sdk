# BasicTokenFlow

main: kit: flow: BasicTokenFlow:
{
  entity: "token",
  kind: "basic",
  name: "BasicTokenFlow",
  step: [
    {
      input: {
        ref: "token_ref01"
      }

      op: "create"
    }

    {
      input: {
        ref: "token_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "token01"
      }

      op: "remove"
    }
  ],
  "key$": "BasicTokenFlow"
}