# BasicAccountFlow

main: kit: flow: BasicAccountFlow:
{
  entity: "account",
  kind: "basic",
  name: "BasicAccountFlow",
  step: [
    {
      input: {
        ref: "account_ref01"
      }

      match: {
        account_id: "account01",
        merchant_id: "merchant01"
      }

      op: "create"
    }

    {
      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "account_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "account_ref01",
        srcdatavar: "account_ref01_data",
        suffix: "_up0",
        textfield: "account_id"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-account_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "account_ref01",
        srcdatavar: "account_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-account_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "account_ref01",
        suffix: "_rm0"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "account_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicAccountFlow"
}