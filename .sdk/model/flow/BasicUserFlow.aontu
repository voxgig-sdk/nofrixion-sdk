# BasicUserFlow

main: kit: flow: BasicUserFlow:
{
  entity: "user",
  kind: "basic",
  name: "BasicUserFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "user_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "user_ref01",
        srcdatavar: "user_ref01_data",
        suffix: "_up0",
        textfield: "email_address"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-user_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicUserFlow"
}