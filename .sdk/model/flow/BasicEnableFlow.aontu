  kind: "basic",
  name: "BasicEnableFlow",
  step: [
    {
      input: {
        ref: "enable_ref01",
        srcdatavar: "enable_ref01_data",
        suffix: "_up0",
        textfield: "approval_callback_url"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-enable_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicEnableFlow"
}