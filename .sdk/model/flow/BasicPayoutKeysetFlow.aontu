# BasicPayoutKeysetFlow

main: kit: flow: BasicPayoutKeysetFlow:
{
  entity: "payout_keyset",
  kind: "basic",
  name: "BasicPayoutKeysetFlow",
  step: [
    {
      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "payout_keyset_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPayoutKeysetFlow"
}