# BasicMerchantAuthorisationSettingFlow

main: kit: flow: BasicMerchantAuthorisationSettingFlow:
{
  entity: "merchant_authorisation_setting",
  kind: "basic",
  name: "BasicMerchantAuthorisationSettingFlow",
  step: [
    {
      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "merchant_authorisation_setting_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicMerchantAuthorisationSettingFlow"
}