# BasicReportFlow

main: kit: flow: BasicReportFlow:
{
  entity: "report",
  kind: "basic",
  name: "BasicReportFlow",
  step: [
    {
      input: {
        ref: "report_ref01",
        srcdatavar: "report_ref01_data",
        suffix: "_up0"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-report_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicReportFlow"
}