# BasicWebhookFlow

main: kit: flow: BasicWebhookFlow:
{
  entity: "webhook",
  kind: "basic",
  name: "BasicWebhookFlow",
  step: [
    {
      input: {
        ref: "webhook_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "webhook01"
      }

      op: "remove"
    }
  ],
  "key$": "BasicWebhookFlow"
}