# BasicWebhookFlow

main: kit: flow: BasicWebhookFlow:
{
  entity: "webhook",
  kind: "basic",
  name: "BasicWebhookFlow",
  step: [
    {
      input: {
        ref: "webhook_ref01"
      }

      match: {
        merchant_id: "merchant01"
      }

      op: "create"
    }

    {
      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "webhook_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "webhook_ref01",
        srcdatavar: "webhook_ref01_data",
        suffix: "_up0",
        textfield: "destination_url"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-webhook_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "webhook_ref01",
        srcdatavar: "webhook_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "webhook01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-webhook_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "webhook_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "webhook01"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      match: {
        merchant_id: "merchant01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "webhook_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicWebhookFlow"
}