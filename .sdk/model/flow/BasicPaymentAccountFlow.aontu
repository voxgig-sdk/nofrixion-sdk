# BasicPaymentAccountFlow

main: kit: flow: BasicPaymentAccountFlow:
{
  entity: "payment_account",
  kind: "basic",
  name: "BasicPaymentAccountFlow",
  step: [
    {
      match: {
        account_id: "account01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "payment_account_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPaymentAccountFlow"
}