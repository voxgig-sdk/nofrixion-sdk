{
  "name": "build-nofrixion-sdk",
  "version": "0.0.1",
  "description": "Nofrixion SDK Project",
  "scripts": {
    "generate": "tsc --build src && voxgig-model model/sdk.aontu",
    "watch-generate": "voxgig-model -w model/sdk.aontu",
    "dry-generate": "tsc --build src && voxgig-model -y model/sdk.aontu",
    "watch-dry-generate": "voxgig-model -w -y model/sdk.aontu",
    "test-model": "voxgig-model test/test.aontu",
    "watch-test-model": "voxgig-model -w test/test.aontu",
    "watch": "tsc --build src -w",
    "build": "tsc --build src",
    "test": "echo no-test",
    "clean": "rm -rf dist dist-test node_modules yarn.lock package-lock.json",
    "reset": "npm run clean && npm i && npm run build && npm test",
    "add-target": "voxgig-sdkgen target add",
    "dry-add-target": "voxgig-sdkgen -y target add",
    "add-feature": "voxgig-sdkgen feature add",
    "dry-add-feature": "voxgig-sdkgen -y feature add"
  },
  "author": "Nofrixion",
  "license": "$$const.License$$",
  "devDependencies": {
    "@types/node": ">=25.6",
    "typescript": ">=6.0",
    "@voxgig/apidef": ">=6.3.6",
    "@voxgig/model": ">=9.2.2",
    "@voxgig/sdkgen": ">=1.3.11",
    "@voxgig/util": ">=0.4",
    "@voxgig/struct": ">=0.1.0",
    "jostraca": ">=0.29",
    "aontu": ">=0.44"
  }
}
